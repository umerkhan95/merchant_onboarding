# Application
DEBUG=false

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_KEY=your-supabase-anon-key
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security
API_KEYS=dev-key-1,dev-key-2

# Rate Limiting
RATE_LIMIT_DEFAULT=10/minute
RATE_LIMIT_ONBOARD=2/minute

# Crawling
MAX_CONCURRENT_BROWSERS=10
MEMORY_THRESHOLD_PERCENT=70.0
CRAWL_BATCH_SIZE=50
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60

# LLM Extraction (for universal product extraction fallback)
LLM_PROVIDER=openai/gpt-4o-mini
LLM_API_KEY=your-openai-api-key
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4000
SCHEMA_CACHE_TTL=604800

# OAuth / Platform Integration
OAUTH_ENCRYPTION_KEY=  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BIGCOMMERCE_CLIENT_ID=
BIGCOMMERCE_CLIENT_SECRET=
BIGCOMMERCE_CALLBACK_URL=http://localhost:8000/api/v1/auth/bigcommerce/callback
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_CALLBACK_URL=http://localhost:8000/api/v1/auth/shopify/callback
